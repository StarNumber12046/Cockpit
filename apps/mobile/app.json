{
  "expo": {
    "name": "Cockpit",
    "slug": "cockpit",
    "owner": "starnumber12046",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cockpit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cockpit.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Cockpit shows your position on the live map."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1220"
      },
      "package": "com.cockpit.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "sitemap": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Cockpit shows your position on the live map."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/FontAwesome.ttf",
            "./assets/fonts/RobotoFlex.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {
        "sitemap": false
      },
      "eas": {
        "projectId": "9fc9eaf5-fdc2-41db-9956-98d55cfccdfb"
      }
    }
  }
}
