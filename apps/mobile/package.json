{
  "name": "@cockpit/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node ../../scripts/expo-dev.mjs",
    "dev:online": "node ../../scripts/expo-dev.mjs",
    "dev:offline": "node ../../scripts/expo-dev.mjs --offline",
    "dev:raw": "expo start --offline",
    "start": "node ../../scripts/expo-dev.mjs",
    "android": "node ../../scripts/expo-dev.mjs --android",
    "ios": "node ../../scripts/expo-dev.mjs --ios",
    "web": "node ../../scripts/expo-dev.mjs --web",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .expo dist"
  },
  "dependencies": {
    "@cockpit/backend": "workspace:*",
    "@cockpit/fr24": "workspace:*",
    "@cockpit/shared": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "convex": "^1.24.8",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.11",
    "typescript": "^5.8.3"
  }
}
