# Convex deployment URL from `npx convex dev` / dashboard
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Google Maps SDK (Android dev/EAS builds; baked into native manifest at build time)
# Create at https://console.cloud.google.com/ — enable "Maps SDK for Android"
GOOGLE_MAPS_API_KEY=

# Optional: Cloudflare Worker FR24 proxy (faster than Convex). See scripts/fr24-edge-worker.js
# EXPO_PUBLIC_FR24_PROXY_URL=https://cockpit-fr24.your-subdomain.workers.dev
